<div class="flex items-center gap-2 flex-wrap justify-between">
  <%# Watchlist button %>
  <% if movie.on_watchlist? %>
    <span class="inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-xs font-medium bg-blue-100 text-blue-800">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
        <path fill-rule="evenodd" d="M12 2.25c-5.108 0-9.25 4.143-9.25 9.25s4.142 9.25 9.25 9.25 9.25-4.143 9.25-9.25S17.108 2.25 12 2.25Zm3.53 7.28a.75.75 0 0 0-1.06-1.06L11 12.94 9.53 11.47a.75.75 0 1 0-1.06 1.06l2 2a.75.75 0 0 0 1.06 0l4-4Z" clip-rule="evenodd" />
      </svg>
      On watchlist
    </span>
  <% else %>
    <%= button_to watchlist_items_path(movie_id: movie.id),
      method: :post,
      data: { turbo: false },
      form_class: "inline",
      class: "inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-xs font-medium bg-gray-100 text-gray-700 hover:bg-gray-200 transition cursor-pointer" do %>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-4 w-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      Add to watchlist
    <% end %>
  <% end %>

  <%# Add to custom list (reuse existing quick-add button) %>
  <% if user_signed_in? %>
    <div class="relative">
      <%= render "add_to_list_button", movie: movie %>
    </div>
  <% end %>

  <%# Watched toggle %>
  <% if movie.seen? %>
    <span class="inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-xs font-medium bg-gray-800 text-gray-100" title="Watched">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
        <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
        <path fill-rule="evenodd" d="M1.323 11.447C2.811 6.976 7.028 3.75 12.001 3.75c4.97 0 9.185 3.223 10.675 7.69.12.362.12.752 0 1.113-1.487 4.471-5.705 7.697-10.677 7.697-4.97 0-9.186-3.223-10.675-7.69a1.762 1.762 0 0 1 0-1.113ZM17.25 12a5.25 5.25 0 1 1-10.5 0 5.25 5.25 0 0 1 10.5 0Z" clip-rule="evenodd" />
      </svg>
      Watched
    </span>
  <% elsif user_signed_in? %>
    <%= button_to viewings_path(movie_id: movie.id),
      method: :post,
      data: { turbo: false },
      form_class: "inline",
      class: "inline-flex items-center justify-center rounded-full h-8 w-8 bg-gray-100 text-gray-700 hover:bg-gray-200 transition cursor-pointer",
      title: "Mark as watched" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
      </svg>
    <% end %>
  <% end %>
</div>
