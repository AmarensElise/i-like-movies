<div class="min-h-screen flex items-center justify-center bg-gray-50 pb-20">
  <div class="max-w-lg w-full mx-auto px-4">
    <%= turbo_frame_tag "quiz_step" do %>
      <div class="bg-white rounded-2xl shadow-lg p-8">
        <p class="text-sm uppercase tracking-wide text-gray-500 mb-2">Step 2 of 5</p>
        <h1 class="text-2xl font-bold text-gray-900 mb-2">How long?</h1>
        <p class="text-gray-600 mb-8">What's your time budget?</p>

        <div class="space-y-3">
          <%= link_to adventurousness_watch_quiz_path(streaming: params[:streaming], length: "under_90", adventurousness: params[:adventurousness]),
                class: "block w-full text-left p-4 rounded-xl border-2 border-gray-200 hover:border-indigo-500 hover:bg-indigo-50 transition-colors" do %>
            <p class="font-semibold text-gray-900">Under 90 minutes</p>
            <p class="text-sm text-gray-500">Quick watch</p>
          <% end %>

          <%= link_to adventurousness_watch_quiz_path(streaming: params[:streaming], length: "over_90", adventurousness: params[:adventurousness]),
                class: "block w-full text-left p-4 rounded-xl border-2 border-gray-200 hover:border-indigo-500 hover:bg-indigo-50 transition-colors" do %>
            <p class="font-semibold text-gray-900">90 minutes or more</p>
            <p class="text-sm text-gray-500">Settle in for a full feature</p>
          <% end %>

          <%= link_to adventurousness_watch_quiz_path(streaming: params[:streaming], length: "any", adventurousness: params[:adventurousness]),
                class: "block w-full text-left p-4 rounded-xl border-2 border-gray-200 hover:border-indigo-500 hover:bg-indigo-50 transition-colors" do %>
            <p class="font-semibold text-gray-900">Any length</p>
            <p class="text-sm text-gray-500">No preference</p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
