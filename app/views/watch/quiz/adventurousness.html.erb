<div class="min-h-screen flex items-center justify-center bg-gray-50 pb-20">
  <div class="max-w-lg w-full mx-auto px-4">
    <%= turbo_frame_tag "quiz_step" do %>
      <div class="bg-white rounded-2xl shadow-lg p-8">
        <p class="text-sm uppercase tracking-wide text-gray-500 mb-2">Step 3 of 5</p>
        <h1 class="text-2xl font-bold text-gray-900 mb-2">How adventurous?</h1>
        <p class="text-gray-600 mb-8">Do you want something familiar or a surprise?</p>

        <div class="space-y-3">
          <%= link_to category_watch_quiz_path(streaming: params[:streaming], length: params[:length], adventurousness: "comfort_zone"),
                class: "block w-full text-left p-4 rounded-xl border-2 border-gray-200 hover:border-indigo-500 hover:bg-indigo-50 transition-colors" do %>
            <p class="font-semibold text-gray-900">Comfort zone</p>
            <p class="text-sm text-gray-500">Only movies on my watchlist featuring a favorite actor</p>
          <% end %>

          <%= link_to category_watch_quiz_path(streaming: params[:streaming], length: params[:length], adventurousness: "lean_familiar"),
                class: "block w-full text-left p-4 rounded-xl border-2 border-gray-200 hover:border-indigo-500 hover:bg-indigo-50 transition-colors" do %>
            <p class="font-semibold text-gray-900">Lean familiar</p>
            <p class="text-sm text-gray-500">Prefer watchlist &amp; favorites, but open to anything</p>
          <% end %>

          <%= link_to category_watch_quiz_path(streaming: params[:streaming], length: params[:length], adventurousness: "no_bias"),
                class: "block w-full text-left p-4 rounded-xl border-2 border-gray-200 hover:border-indigo-500 hover:bg-indigo-50 transition-colors" do %>
            <p class="font-semibold text-gray-900">No bias</p>
            <p class="text-sm text-gray-500">Surprise me — anything goes</p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
