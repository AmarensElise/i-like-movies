<div class="min-h-screen flex items-center justify-center bg-gray-50 pb-20">
  <div class="max-w-lg w-full mx-auto px-4">
    <%= turbo_frame_tag "quiz_step" do %>
      <div class="bg-white rounded-2xl shadow-lg p-8">
        <p class="text-sm uppercase tracking-wide text-gray-500 mb-2">Step 4 of 5</p>
        <h1 class="text-2xl font-bold text-gray-900 mb-2">Pick a category</h1>

        <% if @categories.any? %>
          <p class="text-gray-600 mb-8">Each has at least 5 matching movies.</p>

          <div class="space-y-3">
            <% @categories.each do |cat| %>
              <%= link_to final_watch_quiz_path(
                    streaming: params[:streaming],
                    length: params[:length],
                    adventurousness: params[:adventurousness],
                    category_key: cat[:key],
                    category_label: cat[:label]
                  ),
                  class: "block w-full text-left p-4 rounded-xl border-2 border-gray-200 hover:border-indigo-500 hover:bg-indigo-50 transition-colors" do %>
                <p class="font-semibold text-gray-900"><%= cat[:label] %></p>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-600 mb-6">Not enough movies match your filters for any category. Try loosening your choices.</p>

          <%= link_to "Go back", adventurousness_watch_quiz_path(streaming: params[:streaming], length: params[:length]),
                class: "inline-block bg-indigo-600 text-white font-semibold py-3 px-6 rounded-xl hover:bg-indigo-700 transition-colors" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
