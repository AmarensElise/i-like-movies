<style>
  /* Glitch VHS Title Effect */
  .glitch {
    position: relative;
    display: flex;
    justify-content: center;
    align-content: center;
    height: 100%;
    width: 100%;
    overflow: hidden;
  }

  .glitch .glitch-text {
    animation: jerkwhole 2.5s infinite;
    position: relative;
    padding: 0;
    margin: 0;
  }

  .glitch .glitch-text span {
    position: absolute;
    color: white;
    font-family: 'Young Serif', serif;
    font-size: 4em;
    text-align: center;
    -webkit-filter: blur(1px);
    filter: blur(1px);
    animation: blur 30ms infinite, jerk 50ms infinite;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100vw;
  }

  @media (min-width: 768px) {
    .glitch .glitch-text span {
      font-size: 8em;
    }
  }

  .glitch .glitch-text span:nth-child(1) {
    color: red;
    margin-left: 8px;
    margin-top: -2px;
    -webkit-filter: blur(2px);
    filter: blur(2px);
  }

  .glitch .glitch-text span:nth-child(2) {
    color: green;
    margin-left: 7px;
    -webkit-filter: blur(2px);
    filter: blur(2px);
  }

  .glitch .glitch-text span:nth-child(3) {
    color: blue;
    margin-left: -7px;
    margin-top: 4px;
    -webkit-filter: blur(2px);
    filter: blur(2px);
    animation: jerkblue 0.5s infinite;
  }

  .glitch .glitch-text span:nth-child(4) {
    color: white;
    -webkit-filter: blur(1px);
    filter: blur(1px);
    text-shadow: 0 0 50px rgba(255, 255, 255, 0.4);
  }

  .glitch .glitch-text span:nth-child(5) {
    color: rgba(255, 255, 255, 0.4);
    -webkit-filter: blur(15px);
    filter: blur(15px);
  }

  /* Animations */
  @keyframes blur {
    0%   { filter: blur(1px); opacity: 0.8; }
    50%  { filter: blur(1px); opacity: 1; }
    100% { filter: blur(1px); opacity: 0.6; }
  }

  @keyframes jerk {
    50% { left: calc(50% + 2px); }
    51% { left: 50%; }
  }

  @keyframes jerkblue {
    0%   { left: 50%; }
    30%  { left: 50%; }
    31%  { left: calc(50% - 10px); }
    32%  { left: 50%; }
    98%  { left: 50%; }
    100% { left: calc(50% + 10px); }
  }

  @keyframes jerkwhole {
    30%  { }
    40%  { opacity: 1; top: 0; left: 0; transform: scale(1, 1) skew(0, 0); }
    41%  { opacity: 0.8; top: 0; left: -100px; transform: scale(1, 1.2) skew(20deg, 0); }
    42%  { opacity: 0.8; top: 0; left: 50px; transform: scale(1, 1.2) skew(-40deg, 0); }
    43%  { opacity: 1; top: 0; left: 0; transform: scale(1, 1) skew(0, 0); }
    65%  { }
  }
</style>

<div class="relative min-h-screen w-full overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <%= image_tag "videorental.png", class: "w-full h-full object-cover", alt: "Video Rental" %>
  </div>

  <!-- Overlay for readability -->
  <div class="absolute inset-0 bg-black/40"></div>

  <!-- Glitch Title -->
  <div class="relative z-10 min-h-screen">
    <section class="flex justify-center items-center w-full h-screen m-0" style="background: transparent;">
      <div class="glitch">
        <div class="glitch-text">
          <span>VHS Rental</span>
        </div>
      </div>
    </section>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const original = document.querySelector('.glitch .glitch-text span');
    if (original) {
      const parent = original.parentNode;
      for (let i = 0; i < 4; i++) {
        const clone = original.cloneNode(true);
        parent.insertBefore(clone, parent.firstChild);
      }
    }
  });
</script>
