<div class="min-h-screen bg-gray-50 pb-24">
  <div class="max-w-5xl mx-auto px-4 pt-8">
    <div class="bg-white rounded-2xl shadow-lg p-6 mb-6 text-center">
      <p class="text-sm uppercase tracking-wide text-gray-500 mb-2">Quiz Complete</p>
      <h1 class="text-4xl font-bold text-gray-900 mb-2"><%= quiz.total_score %> total years off</h1>
      <p class="text-gray-600">You answered all 10 questions.</p>
      <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center">
        <%= link_to "Play again", quizzes_path, data: { turbo_method: :post }, class: "bg-indigo-600 text-white font-semibold py-3 px-6 rounded-xl hover:bg-indigo-700 transition-colors" %>
        <%= link_to "View leaderboard", leaderboard_path, class: "bg-gray-100 text-gray-800 font-semibold py-3 px-6 rounded-xl hover:bg-gray-200 transition-colors" %>
      </div>
    </div>

    <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">#</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Movie</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Your Guess</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Actual</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Off By</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Score</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% quiz.quiz_questions.each do |question| %>
              <% years_off = (question.guessed_year - question.actual_year).abs %>
              <% direction = question.guessed_year > question.actual_year ? 'late' : (question.guessed_year < question.actual_year ? 'early' : 'exact') %>
              <tr>
                <td class="px-4 py-3 text-sm text-gray-600"><%= question.position %></td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-3">
                    <% if question.movie.poster_path.present? %>
                      <img src="https://image.tmdb.org/t/p/w92<%= question.movie.poster_path %>" alt="<%= question.movie.title %>" class="w-12 h-16 object-cover rounded" />
                    <% else %>
                      <div class="w-12 h-16 bg-gray-200 rounded flex items-center justify-center text-gray-400">?</div>
                    <% end %>
                    <span class="font-medium text-gray-900"><%= question.movie.title %></span>
                  </div>
                </td>
                <td class="px-4 py-3 text-sm text-gray-700"><%= question.guessed_year %></td>
                <td class="px-4 py-3 text-sm text-gray-700"><%= question.actual_year %></td>
                <td class="px-4 py-3 text-sm text-gray-700">
                  <% if direction == 'exact' %>
                    Exact
                  <% else %>
                    <%= years_off %> year<%= years_off == 1 ? '' : 's' %> <%= direction %>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-sm font-semibold text-indigo-600"><%= question.points_earned %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
