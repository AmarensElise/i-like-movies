<div class="bg-white rounded-2xl shadow-lg overflow-hidden md:grid md:grid-cols-[360px_1fr]"
     data-controller="year-picker"
     data-year-picker-current-year-value="<%= Date.current.year %>">

  <%# Movie poster + title %>
  <div class="h-full min-h-[420px] md:min-h-[560px] overflow-hidden bg-gray-200 w-full">
    <% if question.movie.poster_path.present? %>
      <img src="https://image.tmdb.org/t/p/w500<%= question.movie.poster_path %>"
           alt="<%= question.movie.title %>"
           class="w-full h-full object-cover" />
    <% else %>
      <div class="w-full h-full flex items-center justify-center text-gray-400 text-4xl">?</div>
    <% end %>
  </div>

  <div class="p-6 md:p-8">
    <h2 class="text-xl font-bold text-gray-900 text-center mb-6"><%= question.movie.title %></h2>

    <%= form_with url: quiz_question_path(quiz, question), method: :patch, scope: :quiz_question, data: { turbo: true } do |f| %>
      <%= f.hidden_field :guessed_year, value: '', data: { year_picker_target: 'hiddenInput' } %>

      <%# Year preview %>
      <div class="text-center text-4xl font-mono font-bold text-indigo-600 mb-6 tracking-widest"
           data-year-picker-target="preview">_ _ _ _</div>

      <%# Century step %>
      <div data-year-picker-target="centuryButtons">
        <p class="text-sm text-gray-500 text-center mb-3">Select century</p>
        <div class="grid grid-cols-2 gap-3">
          <button type="button"
                  class="py-3 rounded-xl border-2 border-gray-200 text-gray-700 font-semibold hover:border-indigo-500 hover:text-indigo-600 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-colors"
                  data-year-picker-target="centuryButton"
                  data-action="click->year-picker#selectCentury"
                  data-century="19">1900s</button>
          <button type="button"
                  class="py-3 rounded-xl border-2 border-gray-200 text-gray-700 font-semibold hover:border-indigo-500 hover:text-indigo-600 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-colors"
                  data-year-picker-target="centuryButton"
                  data-action="click->year-picker#selectCentury"
                  data-century="20">2000s</button>
        </div>
      </div>

      <%# Decade step (hidden initially) %>
      <div class="hidden" data-year-picker-target="decadeGrid">
        <div class="flex items-center mb-3">
          <button type="button"
                  class="text-sm text-indigo-600 hover:underline focus:outline-none focus:ring-2 focus:ring-indigo-500 rounded"
              data-action="click->year-picker#backToCentury"><- Back</button>
          <p class="flex-1 text-sm text-gray-500 text-center">Select decade digit</p>
        </div>
        <div class="grid grid-cols-5 md:grid-cols-10 gap-2" id="decade-buttons-container">
          <% (0..9).each do |d| %>
            <button type="button"
                    class="py-2 rounded-lg border-2 border-gray-200 text-gray-700 font-semibold hover:border-indigo-500 hover:text-indigo-600 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-colors"
                    data-year-picker-target="decadeButton"
                    data-action="click->year-picker#selectDecade"
                    data-decade="<%= d %>"><%= d %></button>
          <% end %>
        </div>
      </div>

      <%# Year digit step (hidden initially) %>
      <div class="hidden" data-year-picker-target="yearGrid">
        <div class="flex items-center mb-3">
          <button type="button"
                  class="text-sm text-indigo-600 hover:underline focus:outline-none focus:ring-2 focus:ring-indigo-500 rounded"
              data-action="click->year-picker#backToDecade"><- Back</button>
          <p class="flex-1 text-sm text-gray-500 text-center">Select year digit</p>
        </div>
        <div class="grid grid-cols-5 md:grid-cols-10 gap-2">
          <% (0..9).each do |y| %>
            <button type="button"
                    class="py-2 rounded-lg border-2 border-gray-200 text-gray-700 font-semibold hover:border-indigo-500 hover:text-indigo-600 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-colors"
                    data-year-picker-target="yearButton"
                    data-action="click->year-picker#selectYear"
                    data-year-digit="<%= y %>"><%= y %></button>
          <% end %>
        </div>
      </div>

      <div class="mt-6">
        <%= f.submit "Submit Guess",
              disabled: true,
              data: { year_picker_target: 'submit' },
              class: "w-full bg-indigo-600 text-white font-semibold py-3 px-6 rounded-xl hover:bg-indigo-700 transition-colors cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed" %>
      </div>
    <% end %>
  </div>
</div>
