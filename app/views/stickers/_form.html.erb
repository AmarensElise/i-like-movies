<%# Sticker creation inline form %>
<%= form_with model: sticker, url: stickers_path, class: "flex items-center gap-2 flex-wrap" do |f| %>
  <%= f.text_field :label,
      placeholder: "New sticker name…",
      maxlength: 30,
      class: "border border-gray-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 w-36" %>
  <%= f.color_field :color,
      class: "h-8 w-8 rounded cursor-pointer border-0 p-0" %>
  <%= f.submit "＋ Create",
      class: "text-sm font-medium text-blue-600 hover:text-blue-800 cursor-pointer" %>
<% end %>
